# Supabase (generic names; next.config maps to client for Next.js)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Embed function auth (recommended): generate with `openssl rand -hex 32`
# Set same value in Supabase: supabase secrets set EMBED_API_KEY=<secret>
EMBED_API_KEY=
# JWT Secret from Supabase: Project Settings → API → JWT Secret (raw string, or JWK JSON)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/capybara_ai

# Supabase Auth (Google OAuth)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=your-google-client-secret

# LLM
DEEPSEEK_API_KEY=your-deepseek-key

# App
NODE_ENV=development
